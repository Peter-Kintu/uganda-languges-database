# .env
# Environment variables file - DO NOT COMMIT TO VERSION CONTROL
# Copy this to .env and fill in your actual values

# ====================================
# PROJECT / DJANGO SETTINGS
# ====================================
SECRET_KEY=your-secure-django-secret-key-here
DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# ====================================
# API KEYS FOR JOB APIS
# ====================================
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_APP_KEY=your_adzuna_app_key_here
CAREERJET_API_KEY=your_careerjet_api_key_here
CAREERJET_PUBLISHER_ID=your_careerjet_publisher_id_here
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key_here

# ====================================
# AI NEGOTIATOR (GEMINI API)
# ====================================
GEMINI_API_KEY=your_gemini_api_key_here

# ====================================
# CLOUDINARY MEDIA STORAGE
# ====================================
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ====================================
# GOOGLE OAUTH
# ====================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ====================================
# JOB SEARCH APIS
# ====================================
CAREERJET_API_KEY=your_careerjet_api_key
CAREERJET_PUBLISHER_ID=your_careerjet_publisher_id
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key

# ====================================
# TRANSLATION SERVICES
# ====================================
NLLB_API_URL=https://your-nllb-api-url.onrender.com/translate
SUNBIRD_API_URL=https://api.sunbird.ai
SUNBIRD_API_KEY=your_sunbird_api_key_here
USE_DATABASE_CACHE=False

# Set USE_DATABASE_CACHE=True only after creating the cache table:
# python manage.py createcachetable

# Sunbird AI supported language codes for translation:
# Acholi=ach, English=eng, Igbo=ibo, Lugbara=lgg, Luganda=lug,
# Runyankole=nyn, Swahili=swa, Ateso=teo, Lusoga=xog, Kinyarwanda=kin,
# Lumasaba=myx, Jopadhola=adh, Alur=alz, Bari=bfa, Rukiga=cgg,
# Lugwere=gwr, Kumam=kdi, Karamojong=kdj, Kakwa=keo, Rukonjo=koo,
# Kupsabiny=kpz, Lango=laj, Samia=lsm, Aringa=luc, Ma’di=mhi,
# Pokot=pok, Lugungu=rub, Ruruuli=ruc, Kwamba=rwm, Lubwisi=tlj,
# Lunyole=nuj, Runyoro=nyo

# Optional variables for direct Sunbird API test use:
# SUNBIRD_TEST_TOKEN=your_sunbird_test_token_here
# SUNBIRD_BASE_URL=https://api.sunbird.ai