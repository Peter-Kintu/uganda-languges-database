# .htaccess Security Hardening for africanaai.info
# This file can be placed in your web root (/var/www/html/.htaccess)
# For shared hosting environments that don't allow Apache vhost modification

# ============================================================================
# 1. RESTRICT HTTP METHODS
# ============================================================================
# Block PUT, DELETE, TRACE, CONNECT methods

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{REQUEST_METHOD} ^(PUT|DELETE|TRACE|CONNECT)$
    RewriteRule .* - [F,L]
</IfModule>

# Alternative: Using Limit directive (may work better on some servers)
<LimitExcept GET POST HEAD OPTIONS>
    deny from all
</LimitExcept>

# ============================================================================
# 2. ADD SECURITY HEADERS
# ============================================================================

<IfModule mod_headers.c>
    # Prevent MIME-type sniffing
    Header always set X-Content-Type-Options "nosniff"
    
    # Prevent clickjacking attacks
    Header always set X-Frame-Options "SAMEORIGIN"
    
    # Control referrer information
    Header always set Referrer-Policy "no-referrer-when-downgrade"
    
    # Restrict access to browser features
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
    
    # Legacy XSS protection
    Header always set X-XSS-Protection "1; mode=block"
    
    # Enforce HTTPS for 1 year (31536000 seconds)
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    
    # Content Security Policy - Prevent XSS attacks
    # Adjust 'trusted-domain.com' to your actual trusted domains
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' https://unpkg.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; connect-src 'self' https://api.cloudinary.com https://res.cloudinary.com https://wa.me; media-src 'self' https:; frame-src 'self' https://www.youtube.com https://youtube.com"
</IfModule>

# ============================================================================
# 3. DISABLE DIRECTORY LISTING
# ============================================================================
Options -Indexes

# ============================================================================
# 4. BLOCK ACCESS TO SENSITIVE FILES
# ============================================================================
<FilesMatch "\.(env|git|gitignore|htaccess|htpasswd|ini|conf|cfg|sql|bak|backup|log)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Deny from all
    </IfModule>
</FilesMatch>

# Block access to common admin panels and backup files
<FilesMatch "^(wp-admin|wp-login|wp-config|config|\.htaccess|\.git)">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Deny from all
    </IfModule>
</FilesMatch>

# ============================================================================
# 5. SET PROPER MIME TYPES
# ============================================================================
<IfModule mod_mime.c>
    AddType application/javascript .js
    AddType text/css .css
    AddType font/woff2 .woff2
    AddType font/woff .woff
    AddType application/x-font-ttf .ttf
    AddType image/svg+xml .svg
</IfModule>

# ============================================================================
# 6. ENABLE COMPRESSION
# ============================================================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# ============================================================================
# 7. CACHING HEADERS
# ============================================================================
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Cache images for 1 month
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/gif "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/webp "access plus 30 days"
    ExpiresByType image/svg+xml "access plus 30 days"
    
    # Cache CSS and JavaScript for 2 weeks
    ExpiresByType text/css "access plus 14 days"
    ExpiresByType application/javascript "access plus 14 days"
    
    # Cache fonts for 1 year
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    
    # Don't cache HTML (always check for updates)
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# ============================================================================
# 8. HIDE SERVER INFORMATION
# ============================================================================
# Note: These settings typically require Apache configuration, but we can
# set some headers via .htaccess:

<IfModule mod_headers.c>
    # Remove Apache version from headers (limited effect in .htaccess)
    Header always unset X-Powered-By
    Header unset X-AspNet-Version
    Header unset X-Runtime
</IfModule>

# ============================================================================
# NOTES FOR DEPLOYMENT
# ============================================================================
#
# 1. Place this file in your web root: /var/www/html/.htaccess
#
# 2. Ensure Apache has mod_rewrite and mod_headers enabled:
#    a2enmod rewrite
#    a2enmod headers
#
# 3. Verify syntax by checking Apache error log:
#    tail -f /var/log/apache2/error.log
#
# 4. Test the configuration:
#    curl -I https://africanaai.info
#
# 5. Customize CSP policy if needed:
#    - 'self': This origin
#    - https://unpkg.com: FFmpeg.wasm CDN
#    - https://cdn.jsdelivr.net: Alternative CDN
#    - https://fonts.googleapis.com: Google Fonts
#    - https://api.cloudinary.com: Cloudinary uploads
#    - https://wa.me: WhatsApp links
#
# 6. If you need different policies per path, create additional .htaccess
#    files in subdirectories with more specific rules.
