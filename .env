# .env file for Django project

# ====================================
# PROJECT / DJANGO SETTINGS
# ====================================
# SECURITY WARNING: Keep your actual SECRET_KEY highly secure.
# Generate a new, unique key for production.
SECRET_KEY='your-secure-django-secret-key-here'

# Set to False in production
DEBUG=True

# Database URL for Django's dj_database_url
# Example for a local SQLite database (for development):
# DATABASE_URL=sqlite:///db.sqlite3
# Example for a Neon Postgres database:
# DATABASE_URL='postgresql://user:password@host:port/dbname?sslmode=require'
# If deploying to a service like Render, you might not need to set this here
# as the service provides it automatically.

# ====================================
# AI NEGOTIATOR (GEMINI API)
# ====================================
# This key is required for the AI Bot to connect and resolve the "AI Negotiator is Offline" error.
# Get your key from Google AI Studio.
GEMINI_API_KEY='AIzaSyD-gBjm-9ectc1R-heErSiTThS2xGUVvAI'

# ====================================
# CLOUDINARY MEDIA STORAGE
# ====================================
# These are required for media uploads (like product images)
CLOUDINARY_CLOUD_NAME='your-cloudinary-cloud-name'
CLOUDINARY_API_KEY='your-cloudinary-api-key'
CLOUDINARY_API_SECRET='your-cloudinary-api-secret'

